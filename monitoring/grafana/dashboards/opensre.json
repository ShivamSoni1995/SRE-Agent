{
  "title": "OpenSRE Mini",
  "uid": "opensre-mini",
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Incidents analyzed (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(opensre_incidents_analyzed_total{status='success'})",
        "legendFormat": "Total"
      }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 10 },
          { "color": "red", "value": 50 }
        ]}}}
    },
    {
      "id": 2,
      "title": "Incidents by severity",
      "type": "piechart",
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "targets": [{
        "expr": "opensre_incidents_by_severity_total",
        "legendFormat": "{{ severity }}"
      }]
    },
    {
      "id": 3,
      "title": "Avg RCA confidence",
      "type": "stat",
      "gridPos": { "x": 9, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.5, rate(opensre_rca_confidence_score_bucket[5m]))",
        "legendFormat": "p50 confidence"
      }],
      "fieldConfig": { "defaults": {
        "unit": "percentunit",
        "thresholds": { "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 0.5 },
          { "color": "green", "value": 0.75 }
        ]}}}
    },
    {
      "id": 4,
      "title": "Avg evaluation score",
      "type": "stat",
      "gridPos": { "x": 13, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.5, rate(opensre_rca_evaluation_score_bucket[5m]))",
        "legendFormat": "p50 eval score"
      }],
      "fieldConfig": { "defaults": {
        "unit": "percentunit",
        "thresholds": { "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 0.5 },
          { "color": "green", "value": 0.75 }
        ]}}}
    },
    {
      "id": 5,
      "title": "Gemini API calls",
      "type": "stat",
      "gridPos": { "x": 17, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(opensre_gemini_api_calls_total)",
        "legendFormat": "Total calls"
      }]
    },
    {
      "id": 6,
      "title": "Analysis pipeline duration (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(opensre_analysis_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(opensre_analysis_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "title": "HTTP request rate by endpoint",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "targets": [{
        "expr": "rate(opensre_http_requests_total[2m])",
        "legendFormat": "{{ method }} {{ endpoint }} {{ status_code }}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8,
      "title": "Gemini API duration (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(opensre_gemini_api_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(opensre_gemini_api_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 9,
      "title": "Gemini outcomes",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [{
        "expr": "rate(opensre_gemini_api_calls_total[2m])",
        "legendFormat": "{{ outcome }}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 10,
      "title": "Last ingested — CPU %",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 5 },
      "targets": [{ "expr": "opensre_last_ingested_cpu_percent", "legendFormat": "CPU" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 70 },
          { "color": "red", "value": 90 }
        ]}}}
    },
    {
      "id": 11,
      "title": "Last ingested — Memory %",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 5 },
      "targets": [{ "expr": "opensre_last_ingested_memory_percent", "legendFormat": "Memory" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 75 },
          { "color": "red", "value": 90 }
        ]}}}
    },
    {
      "id": 12,
      "title": "Last ingested — Latency ms",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 5 },
      "targets": [{ "expr": "opensre_last_ingested_latency_ms", "legendFormat": "Latency" }],
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0, "max": 5000,
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 500 },
          { "color": "red", "value": 1000 }
        ]}}}
    },
    {
      "id": 13,
      "title": "Last ingested — Error rate %",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 5 },
      "targets": [{ "expr": "opensre_last_ingested_error_rate_percent", "legendFormat": "Error rate" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 5 },
          { "color": "red", "value": 10 }
        ]}}}
    },
    {
      "id": 14,
      "title": "Slack notifications",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 5 },
      "targets": [{
        "expr": "rate(opensre_slack_notifications_total[5m])",
        "legendFormat": "{{ outcome }}"
      }]
    },
    {
      "id": 15,
      "title": "Low confidence RCAs (possible hallucination)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 5 },
      "targets": [{
        "expr": "increase(opensre_low_confidence_rca_total[5m])",
        "legendFormat": "Low confidence RCAs"
      }],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } } }
    }
  ]
}
