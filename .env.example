# ── Gemini ──────────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Storage ──────────────────────────────────────────────────────────────────
# Set to "true" to use Firestore instead of SQLite
USE_FIRESTORE=false

# SQLite path (used when USE_FIRESTORE=false)
SQLITE_PATH=data/incidents.db

# ── Slack ────────────────────────────────────────────────────────────────────
# Incoming webhook URL from https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Only notify for incidents at this severity or above: normal | warning | critical
SLACK_SEVERITY_THRESHOLD=warning

# ── Cloud Run ────────────────────────────────────────────────────────────────
# Your deployed Cloud Run URL (used in Slack notification links)
SERVICE_URL=https://opensre-mini-xxx-uc.a.run.app
